# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Resend API Key for email invitations
EXPO_PUBLIC_RESEND_API_KEY=your-resend-api-key

# App URL for invitation links (update with your actual app URL)
EXPO_PUBLIC_APP_URL=orderlyflow://

# From email address (update with your verified domain)
EXPO_PUBLIC_FROM_EMAIL=no-reply@orderlyflow.com
